# Web local en el mismo Mac donde corre el servidor:
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# Expo Go en un iPhone/Android físico:
# Usa la IP LAN del Mac, no localhost.
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.38:3000

# Producción, por ejemplo Heroku/Render/Railway/Fly:
# EXPO_PUBLIC_SOCKET_URL=https://tu-servidor-shopp.herokuapp.com